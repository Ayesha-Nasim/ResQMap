{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "AIzaSyA4gefyqUIwM8H1v5h6Y6pOt_sTzPw_nEQ"
      }
    },

    "android": {
      "package": "com.resqmap.mobile",
      "usesCleartextTraffic": true,                
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.WAKE_LOCK",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#E6F4FE"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyA4gefyqUIwM8H1v5h6Y6pOt_sTzPw_nEQ"
        }
      }
    },

    "web": {
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow this app to access your photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission":
            "Allow this app to access your location."
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "googleRedirectUri": "https://auth.expo.dev/@ayena/mobile",
      "expoClientId": "1063358640985-8l0c1luv17umno22ehhapts0mhj1thor.apps.googleusercontent.com",
      "router": {},
      "eas": {
        "projectId": "5bda12e8-7d11-4f96-8972-676b1be8be1d"
      }
    }
  }
}
